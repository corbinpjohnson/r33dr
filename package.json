{
  "name": "vibereader",
  "version": "0.1.0",
  "description": "Speed-read EPUB and PDF books with RSVP, OCR for scanned pages, and on-device AI chapter summaries. Electron + React desktop app.",
  "license": "MIT",
  "author": "Corbin Johnson",
  "repository": {
    "type": "git",
    "url": "https://github.com/corbinq27/vibereader.git"
  },
  "type": "module",
  "main": "electron-main.cjs",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "start": "electron .",
    "build:swift": "swift build -c release --package-path SummaryHelper && cp SummaryHelper/.build/release/SummaryHelper bin/SummaryHelper",
    "dist": "npm run build:swift && npm run build && npx electron-builder",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "build": {
    "appId": "com.vibereader.app",
    "productName": "VibeReader",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      "electron-main.cjs",
      "preload.cjs"
    ],
    "extraResources": [
      { "from": "bin/SummaryHelper", "to": "SummaryHelper" }
    ],
    "mac": {
      "category": "public.app-category.education",
      "target": "dir"
    }
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.0",
    "epubjs": "^0.3.93",
    "lucide-react": "^1.17.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "tesseract.js": "^5.1.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "concurrently": "^10.0.3",
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^25.0.1",
    "playwright": "^1.60.0",
    "postcss": "^8.5.15",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-pwa": "^1.3.0",
    "vitest": "^3.2.6",
    "wait-on": "^9.0.10"
  }
}
